{
  "version": 2,
  "routes": [
    {
      "src": "/api/recommend",
      "dest": "/api/recommend.py"
    },
    {
      "src": "/api/weather",
      "dest": "/api/weather.py"
    },
    {
      "src": "/api/travel",
      "dest": "/api/travel.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}